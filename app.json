{
  "id": "de.cqnc.lumina",
  "version": "0.1.0",
  "compatibility": ">=5.0.0",
  "sdk": 3,
  "platforms": ["local"],
  "name": {
    "en": "Lumina",
    "de": "Lumina"
  },
  "description": {
    "en": "Lights that follow the sun. Adaptive color temperature and brightness, smoothly, throughout the day.",
    "de": "Beleuchtung, die der Sonne folgt. Adaptive Farbtemperatur und Helligkeit, smooth über den ganzen Tag."
  },
  "category": ["lights"],
  "permissions": [
    "homey:manager:api",
    "homey:manager:geolocation"
  ],
  "api": {
    "getLog":        { "method": "GET",  "path": "/log" },
    "getFields":     { "method": "GET",  "path": "/fields" },
    "getZones":      { "method": "GET",  "path": "/zones" },
    "postAssignZone":{ "method": "POST", "path": "/zones/assign" },
    "postZoneUpdate":{ "method": "POST", "path": "/zones/update" },
    "postCurve":     { "method": "POST", "path": "/curve" }
  },
  "flow": {
    "actions": [
      {
        "id": "set_mode",
        "title": { "en": "Set mode", "de": "Modus setzen" },
        "titleFormatted": {
          "en": "Set mode to [[mode]]",
          "de": "Modus auf [[mode]] setzen"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=zone",
            "title": { "en": "Zone", "de": "Zone" }
          },
          {
            "name": "mode",
            "type": "dropdown",
            "title": { "en": "Mode", "de": "Modus" },
            "values": [
              { "id": "off",   "label": { "en": "Off",      "de": "Aus" } },
              { "id": "day",   "label": { "en": "Adaptive", "de": "Adaptiv" } },
              { "id": "night", "label": { "en": "Night",    "de": "Nacht" } }
            ]
          }
        ]
      },
      {
        "id": "smart_on",
        "title": { "en": "Smart turn on", "de": "Smart einschalten" },
        "titleFormatted": {
          "en": "Smart turn on [[target]]",
          "de": "[[target]] smart einschalten"
        },
        "hint": {
          "en": "Turns the chosen light on with the current adaptive brightness and color temperature in one atomic command, so it wakes at the right state instead of flashing the lamp's last-stored value.",
          "de": "Schaltet die gewählte Lampe mit aktuellem Adaptive-Wert ein — in einem atomaren Command, damit sie direkt im richtigen Zustand hochkommt statt kurz den alten zu zeigen."
        },
        "args": [
          {
            "name": "target",
            "type": "autocomplete",
            "title": { "en": "Light", "de": "Lampe" },
            "placeholder": { "en": "Pick a light…", "de": "Lampe wählen…" }
          }
        ]
      }
    ],
    "conditions": [
      {
        "id": "mode_is",
        "title": { "en": "Mode is ...", "de": "Modus ist ..." },
        "titleFormatted": {
          "en": "Mode !{{is|is not}} [[mode]]",
          "de": "Modus !{{ist|ist nicht}} [[mode]]"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=zone",
            "title": { "en": "Zone", "de": "Zone" }
          },
          {
            "name": "mode",
            "type": "dropdown",
            "title": { "en": "Mode", "de": "Modus" },
            "values": [
              { "id": "off",   "label": { "en": "Off",      "de": "Aus" } },
              { "id": "day",   "label": { "en": "Adaptive", "de": "Adaptiv" } },
              { "id": "night", "label": { "en": "Night",    "de": "Nacht" } }
            ]
          }
        ]
      }
    ]
  },
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png"
  },
  "author": {
    "name": "3cheesehigh",
    "email": "hello@3cheesehigh.com"
  },
  "source": "https://github.com/3cheesehigh/homey-lumina",
  "bugs": {
    "url": "https://github.com/3cheesehigh/homey-lumina/issues"
  },
  "support": "mailto:hello@3cheesehigh.com",
  "brandColor": "#f59e0b",
  "capabilities": {
    "adaptive_kelvin": {
      "type": "number",
      "title": { "en": "Color temperature", "de": "Farbtemperatur" },
      "units": { "en": "K", "de": "K" },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "decimals": 0
    },
    "adaptive_dim": {
      "type": "number",
      "title": { "en": "Brightness", "de": "Helligkeit" },
      "units": { "en": "%", "de": "%" },
      "min": 0,
      "max": 100,
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "decimals": 0
    },
    "measure_sun_elevation": {
      "type": "number",
      "title": { "en": "Sun elevation", "de": "Sonnenstand" },
      "units": { "en": "°", "de": "°" },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "decimals": 1,
      "insights": true
    },
    "adaptive_mode": {
      "type": "enum",
      "title": { "en": "Mode", "de": "Modus" },
      "getable": true,
      "setable": true,
      "uiComponent": "picker",
      "values": [
        { "id": "off",   "title": { "en": "Off",      "de": "Aus" } },
        { "id": "day",   "title": { "en": "Adaptive", "de": "Adaptiv" } },
        { "id": "night", "title": { "en": "Night",    "de": "Nacht" } }
      ]
    }
  },
  "drivers": [
    {
      "id": "zone",
      "name": {
        "en": "Lumina Zone",
        "de": "Lumina-Zone"
      },
      "class": "other",
      "capabilities": [
        "adaptive_mode",
        "adaptive_kelvin",
        "adaptive_dim",
        "measure_sun_elevation"
      ],
      "platforms": ["local"],
      "connectivity": ["lan"],
      "images": {
        "small": "/drivers/zone/assets/images/small.png",
        "large": "/drivers/zone/assets/images/large.png"
      },
      "pair": [
        { "id": "setup",         "navigation": { "next": "list_devices" } },
        { "id": "list_devices",  "template": "list_devices", "navigation": { "next": "add_devices" } },
        { "id": "add_devices",   "template": "add_devices" }
      ],
      "settings": []
    }
  ]
}
