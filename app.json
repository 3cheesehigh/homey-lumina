{
  "id": "com.3cheesehigh.lumina",
  "version": "0.2.1",
  "compatibility": ">=12.5.0",
  "sdk": 3,
  "platforms": [
    "local"
  ],
  "name": {
    "en": "Lumina",
    "de": "Lumina"
  },
  "description": {
    "en": "Lights that follow the sun.",
    "de": "Licht, das der Sonne folgt."
  },
  "category": [
    "tools"
  ],
  "permissions": [
    "homey:manager:api",
    "homey:manager:geolocation"
  ],
  "api": {
    "getLog": {
      "method": "GET",
      "path": "/log"
    },
    "getFields": {
      "method": "GET",
      "path": "/fields"
    },
    "getZones": {
      "method": "GET",
      "path": "/zones"
    },
    "getAvailableZones": {
      "method": "GET",
      "path": "/zones/available"
    },
    "postZoneUpsert": {
      "method": "POST",
      "path": "/zones/upsert"
    },
    "postZoneRemove": {
      "method": "POST",
      "path": "/zones/remove"
    },
    "postCurve": {
      "method": "POST",
      "path": "/curve"
    }
  },
  "flow": {
    "actions": [
      {
        "id": "set_mode",
        "title": {
          "en": "Set mode",
          "de": "Modus setzen"
        },
        "titleFormatted": {
          "en": "Set [[zone]] mode to [[mode]]",
          "de": "[[zone]] auf [[mode]] setzen"
        },
        "args": [
          {
            "name": "zone",
            "type": "autocomplete",
            "title": {
              "en": "Zone",
              "de": "Bereich"
            },
            "placeholder": {
              "en": "Pick a zone…",
              "de": "Bereich wählen…"
            }
          },
          {
            "name": "mode",
            "type": "dropdown",
            "title": {
              "en": "Mode",
              "de": "Modus"
            },
            "values": [
              {
                "id": "off",
                "label": {
                  "en": "Off",
                  "de": "Aus"
                }
              },
              {
                "id": "day",
                "label": {
                  "en": "Adaptive",
                  "de": "Adaptiv"
                }
              },
              {
                "id": "night",
                "label": {
                  "en": "Night",
                  "de": "Nacht"
                }
              }
            ]
          }
        ]
      },
      {
        "id": "smart_on",
        "title": {
          "en": "Smart turn on",
          "de": "Smart einschalten"
        },
        "titleFormatted": {
          "en": "Smart turn on [[target]]",
          "de": "[[target]] smart einschalten"
        },
        "hint": {
          "en": "Turns the chosen light on with the current adaptive brightness and color temperature in one atomic command, so it wakes at the right state instead of flashing the lamp's last-stored value.",
          "de": "Schaltet die gewählte Lampe mit aktuellem Adaptive-Wert ein — in einem atomaren Command, damit sie direkt im richtigen Zustand hochkommt statt kurz den alten zu zeigen."
        },
        "args": [
          {
            "name": "target",
            "type": "autocomplete",
            "title": {
              "en": "Light",
              "de": "Lampe"
            },
            "placeholder": {
              "en": "Pick a light…",
              "de": "Lampe wählen…"
            }
          }
        ]
      },
      {
        "id": "smart_toggle",
        "title": {
          "en": "Smart toggle",
          "de": "Smart umschalten"
        },
        "titleFormatted": {
          "en": "Smart toggle [[target]]",
          "de": "[[target]] smart umschalten"
        },
        "hint": {
          "en": "If the light is off, turns it on with the current adaptive brightness and color temperature. If it's already on, turns it off. Lets a single wall-switch press do the right thing without a Flow condition.",
          "de": "Ist die Lampe aus, wird sie mit aktuellem Adaptive-Wert eingeschaltet. Ist sie an, wird sie ausgeschaltet. So macht ein Wandschalter das Richtige ohne Flow-Bedingung."
        },
        "args": [
          {
            "name": "target",
            "type": "autocomplete",
            "title": {
              "en": "Light",
              "de": "Lampe"
            },
            "placeholder": {
              "en": "Pick a light…",
              "de": "Lampe wählen…"
            }
          }
        ]
      },
      {
        "id": "cycle_mode",
        "title": {
          "en": "Cycle mode",
          "de": "Modus durchwechseln"
        },
        "titleFormatted": {
          "en": "Cycle [[zone]] through [[modes]]",
          "de": "[[zone]] durch [[modes]] cyceln"
        },
        "hint": {
          "en": "Cycles the zone through the selected modes in the order Off → Adaptive → Night, skipping unselected ones. Lets one button press step through e.g. Adaptive ↔ Night.",
          "de": "Wechselt die Zone in der Reihenfolge Aus → Adaptiv → Nacht durch die ausgewählten Modi und überspringt die übrigen. So macht ein Tastendruck z.B. Adaptiv ↔ Nacht."
        },
        "args": [
          {
            "name": "zone",
            "type": "autocomplete",
            "title": {
              "en": "Zone",
              "de": "Bereich"
            },
            "placeholder": {
              "en": "Pick a zone…",
              "de": "Bereich wählen…"
            }
          },
          {
            "name": "modes",
            "type": "multiselect",
            "conjunction": "or",
            "title": {
              "en": "Modes",
              "de": "Modi"
            },
            "values": [
              {
                "id": "off",
                "title": {
                  "en": "Off",
                  "de": "Aus"
                }
              },
              {
                "id": "day",
                "title": {
                  "en": "Adaptive",
                  "de": "Adaptiv"
                }
              },
              {
                "id": "night",
                "title": {
                  "en": "Night",
                  "de": "Nacht"
                }
              }
            ]
          }
        ]
      }
    ],
    "triggers": [
      {
        "id": "mode_changed",
        "title": {
          "en": "Mode changed",
          "de": "Modus geändert"
        },
        "titleFormatted": {
          "en": "[[zone]] mode changed to [[mode]]",
          "de": "[[zone]] Modus auf [[mode]] gewechselt"
        },
        "hint": {
          "en": "Fires whenever the selected zone changes to the selected mode (via app, Flow, or widget).",
          "de": "Wird ausgelöst, sobald der gewählte Bereich auf den gewählten Modus wechselt (über App, Flow oder Widget)."
        },
        "args": [
          {
            "name": "zone",
            "type": "autocomplete",
            "title": {
              "en": "Zone",
              "de": "Bereich"
            },
            "placeholder": {
              "en": "Pick a zone…",
              "de": "Bereich wählen…"
            }
          },
          {
            "name": "mode",
            "type": "dropdown",
            "title": {
              "en": "Mode",
              "de": "Modus"
            },
            "values": [
              { "id": "off",   "label": { "en": "Off",      "de": "Aus" } },
              { "id": "day",   "label": { "en": "Adaptive", "de": "Adaptiv" } },
              { "id": "night", "label": { "en": "Night",    "de": "Nacht" } }
            ]
          }
        ]
      }
    ],
    "conditions": [
      {
        "id": "mode_is",
        "title": {
          "en": "Mode is ...",
          "de": "Modus ist ..."
        },
        "titleFormatted": {
          "en": "[[zone]] mode !{{is|is not}} [[mode]]",
          "de": "[[zone]] Modus !{{ist|ist nicht}} [[mode]]"
        },
        "args": [
          {
            "name": "zone",
            "type": "autocomplete",
            "title": {
              "en": "Zone",
              "de": "Bereich"
            },
            "placeholder": {
              "en": "Pick a zone…",
              "de": "Bereich wählen…"
            }
          },
          {
            "name": "mode",
            "type": "dropdown",
            "title": {
              "en": "Mode",
              "de": "Modus"
            },
            "values": [
              {
                "id": "off",
                "label": {
                  "en": "Off",
                  "de": "Aus"
                }
              },
              {
                "id": "day",
                "label": {
                  "en": "Adaptive",
                  "de": "Adaptiv"
                }
              },
              {
                "id": "night",
                "label": {
                  "en": "Night",
                  "de": "Nacht"
                }
              }
            ]
          }
        ]
      }
    ]
  },
  "widgets": {
    "zone-mode": {
      "id": "zone-mode",
      "name": {
        "en": "Lumina zone mode",
        "de": "Lumina-Bereich Modus"
      },
      "height": 96,
      "settings": [
        {
          "id": "zone",
          "type": "autocomplete",
          "title": {
            "en": "Zone",
            "de": "Bereich"
          }
        }
      ],
      "api": {
        "getStatus": { "method": "GET", "path": "/status" },
        "setMode": { "method": "POST", "path": "/mode" }
      }
    }
  },
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png"
  },
  "author": {
    "name": "3cheesehigh",
    "email": "hello@3cheesehigh.com"
  },
  "source": "https://github.com/3cheesehigh/homey-lumina",
  "bugs": {
    "url": "https://github.com/3cheesehigh/homey-lumina/issues"
  },
  "support": "mailto:hello@3cheesehigh.com",
  "brandColor": "#f59e0b"
}