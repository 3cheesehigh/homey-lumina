{
  "id": "com.3cheesehigh.lumina",
  "version": "0.6.2",
  "compatibility": ">=12.5.0",
  "sdk": 3,
  "platforms": [
    "local"
  ],
  "name": {
    "en": "Lumina",
    "de": "Lumina"
  },
  "description": {
    "en": "Adaptive lighting that follows the sun, with motion-aware dimming and auto-off.",
    "de": "Adaptive Beleuchtung, die der Sonne folgt — mit bewegungsabhängigem Dimmen und Auto-Aus."
  },
  "category": [
    "tools"
  ],
  "permissions": [
    "homey:manager:api",
    "homey:manager:geolocation"
  ],
  "api": {
    "getLog": {
      "method": "GET",
      "path": "/log"
    },
    "getFields": {
      "method": "GET",
      "path": "/fields"
    },
    "getZones": {
      "method": "GET",
      "path": "/zones"
    },
    "getAvailableZones": {
      "method": "GET",
      "path": "/zones/available"
    },
    "postZoneUpsert": {
      "method": "POST",
      "path": "/zones/upsert"
    },
    "postZoneRemove": {
      "method": "POST",
      "path": "/zones/remove"
    },
    "postCurve": {
      "method": "POST",
      "path": "/curve"
    }
  },
  "flow": {
    "actions": [
      {
        "id": "set_mode",
        "title": {
          "en": "Set mode",
          "de": "Modus setzen"
        },
        "titleFormatted": {
          "en": "Set [[zone]] mode to [[mode]]",
          "de": "[[zone]] auf [[mode]] setzen"
        },
        "args": [
          {
            "name": "zone",
            "type": "autocomplete",
            "title": {
              "en": "Zone",
              "de": "Bereich"
            },
            "placeholder": {
              "en": "Pick a zone…",
              "de": "Bereich wählen…"
            }
          },
          {
            "name": "mode",
            "type": "dropdown",
            "title": {
              "en": "Mode",
              "de": "Modus"
            },
            "values": [
              {
                "id": "off",
                "label": {
                  "en": "Off",
                  "de": "Aus"
                }
              },
              {
                "id": "day",
                "label": {
                  "en": "Adaptive",
                  "de": "Adaptiv"
                }
              },
              {
                "id": "night",
                "label": {
                  "en": "Night",
                  "de": "Nacht"
                }
              }
            ]
          }
        ]
      },
      {
        "id": "smart_on",
        "title": {
          "en": "Smart turn on",
          "de": "Smart einschalten"
        },
        "titleFormatted": {
          "en": "Smart turn on [[target]]",
          "de": "[[target]] smart einschalten"
        },
        "hint": {
          "en": "Turns the chosen light on with the current adaptive brightness and color temperature in one atomic command, so it wakes at the right state instead of flashing the lamp's last-stored value.",
          "de": "Schaltet die gewählte Lampe mit aktuellem Adaptive-Wert ein — in einem atomaren Command, damit sie direkt im richtigen Zustand hochkommt statt kurz den alten zu zeigen."
        },
        "args": [
          {
            "name": "target",
            "type": "autocomplete",
            "title": {
              "en": "Light",
              "de": "Lampe"
            },
            "placeholder": {
              "en": "Pick a light…",
              "de": "Lampe wählen…"
            }
          }
        ]
      },
      {
        "id": "smart_toggle",
        "title": {
          "en": "Smart toggle",
          "de": "Smart umschalten"
        },
        "titleFormatted": {
          "en": "Smart toggle [[target]]",
          "de": "[[target]] smart umschalten"
        },
        "hint": {
          "en": "If the light is off, turns it on with the current adaptive brightness and color temperature. If it's already on, turns it off. Lets a single wall-switch press do the right thing without a Flow condition.",
          "de": "Ist die Lampe aus, wird sie mit aktuellem Adaptive-Wert eingeschaltet. Ist sie an, wird sie ausgeschaltet. So macht ein Wandschalter das Richtige ohne Flow-Bedingung."
        },
        "args": [
          {
            "name": "target",
            "type": "autocomplete",
            "title": {
              "en": "Light",
              "de": "Lampe"
            },
            "placeholder": {
              "en": "Pick a light…",
              "de": "Lampe wählen…"
            }
          }
        ]
      },
      {
        "id": "cycle_mode",
        "title": {
          "en": "Cycle mode",
          "de": "Modus durchwechseln"
        },
        "titleFormatted": {
          "en": "Cycle [[zone]] through [[modes]]",
          "de": "[[zone]] durch [[modes]] cyceln"
        },
        "hint": {
          "en": "Cycles the zone through the selected modes in the order Off → Adaptive → Night, skipping unselected ones. Lets one button press step through e.g. Adaptive ↔ Night.",
          "de": "Wechselt die Zone in der Reihenfolge Aus → Adaptiv → Nacht durch die ausgewählten Modi und überspringt die übrigen. So macht ein Tastendruck z.B. Adaptiv ↔ Nacht."
        },
        "args": [
          {
            "name": "zone",
            "type": "autocomplete",
            "title": {
              "en": "Zone",
              "de": "Bereich"
            },
            "placeholder": {
              "en": "Pick a zone…",
              "de": "Bereich wählen…"
            }
          },
          {
            "name": "modes",
            "type": "multiselect",
            "conjunction": "or",
            "title": {
              "en": "Modes",
              "de": "Modi"
            },
            "values": [
              {
                "id": "off",
                "title": {
                  "en": "Off",
                  "de": "Aus"
                }
              },
              {
                "id": "day",
                "title": {
                  "en": "Adaptive",
                  "de": "Adaptiv"
                }
              },
              {
                "id": "night",
                "title": {
                  "en": "Night",
                  "de": "Nacht"
                }
              }
            ]
          }
        ]
      },
      {
        "id": "presence_dim_light",
        "title": {
          "en": "Dim light & auto-off after delay",
          "de": "Lampe dimmen & Auto-Aus nach Verzögerung"
        },
        "titleFormatted": {
          "en": "Dim [[target]] [[mode]] [[percent]]%, off after [[seconds]]s over [[fade]]s fade",
          "de": "[[target]] [[mode]] [[percent]]% dimmen, nach [[seconds]]s über [[fade]]s Fade aus"
        },
        "hint": {
          "en": "Wire to a motion sensor's 'no motion' event. Dims the lamp, holds for the given seconds, then fades to 0 over the fade seconds and turns off. Mode 'by' = current × percent (e.g. lamp at 80% with 50% → 40%). Mode 'to' = absolute target (e.g. 80% → 50%). Fade 0 = no fade, hard off. Re-firing replaces the timer. A Smart turn on for the lamp cancels the auto-off and restores the adaptive value.",
          "de": "An das 'Keine Bewegung'-Event eines Bewegungsmelders hängen. Dimmt die Lampe, hält die Hold-Sekunden, fadet dann über die Fade-Sekunden auf 0 und schaltet aus. Modus 'um' = aktuelle × Prozent (z.B. Lampe bei 80% mit 50% → 40%). Modus 'auf' = absoluter Zielwert (z.B. 80% → 50%). Fade 0 = ohne Fade, hart aus. Erneutes Auslösen ersetzt den Timer. Ein Smart-Einschalten der Lampe bricht das Auto-Aus ab und stellt den Adaptiv-Wert wieder her."
        },
        "args": [
          {
            "name": "target",
            "type": "autocomplete",
            "title": {
              "en": "Light",
              "de": "Lampe"
            },
            "placeholder": {
              "en": "Pick a light…",
              "de": "Lampe wählen…"
            }
          },
          {
            "name": "mode",
            "type": "dropdown",
            "title": {
              "en": "Reduction mode",
              "de": "Reduktionsmodus"
            },
            "values": [
              {
                "id": "relative",
                "label": {
                  "en": "by",
                  "de": "um"
                }
              },
              {
                "id": "absolute",
                "label": {
                  "en": "to",
                  "de": "auf"
                }
              }
            ]
          },
          {
            "name": "percent",
            "type": "number",
            "title": {
              "en": "Percent",
              "de": "Prozent"
            },
            "min": 1,
            "max": 99,
            "step": 1,
            "placeholder": {
              "en": "50",
              "de": "50"
            }
          },
          {
            "name": "seconds",
            "type": "number",
            "title": {
              "en": "Auto-off after (s)",
              "de": "Auto-Aus nach (s)"
            },
            "min": 1,
            "max": 3600,
            "step": 1,
            "placeholder": {
              "en": "30",
              "de": "30"
            }
          },
          {
            "name": "fade",
            "type": "number",
            "title": {
              "en": "Fade-out (s)",
              "de": "Fade-Dauer (s)"
            },
            "min": 0,
            "max": 60,
            "step": 1,
            "placeholder": {
              "en": "5",
              "de": "5"
            }
          }
        ]
      },
      {
        "id": "presence_dim_light_default",
        "title": {
          "en": "Dim light & auto-off (defaults)",
          "de": "Lampe dimmen & Auto-Aus (Standardwerte)"
        },
        "titleFormatted": {
          "en": "Dim [[target]] using Lumina presence defaults",
          "de": "[[target]] mit Lumina-Standardwerten dimmen & ausschalten"
        },
        "hint": {
          "en": "Same as 'Dim light & auto-off after delay', but reduction mode, percent, hold seconds, and fade-out duration come from the Lumina settings page ('Presence defaults'). Use this when all your motion-detector flows should share the same numbers — change them once in settings and every flow follows.",
          "de": "Wie 'Lampe dimmen & Auto-Aus nach Verzögerung', aber Reduktionsmodus, Prozent, Hold-Sekunden und Fade-Dauer kommen aus den Lumina-Einstellungen ('Bewegungs-Standards'). Praktisch, wenn alle Bewegungsmelder-Flows dieselben Werte teilen sollen — einmal in den Einstellungen ändern und alle Flows folgen."
        },
        "args": [
          {
            "name": "target",
            "type": "autocomplete",
            "title": {
              "en": "Light",
              "de": "Lampe"
            },
            "placeholder": {
              "en": "Pick a light…",
              "de": "Lampe wählen…"
            }
          }
        ]
      }
    ],
    "triggers": [
      {
        "id": "mode_changed",
        "title": {
          "en": "Mode changed",
          "de": "Modus geändert"
        },
        "titleFormatted": {
          "en": "[[zone]] mode changed to [[mode]]",
          "de": "[[zone]] Modus auf [[mode]] gewechselt"
        },
        "hint": {
          "en": "Fires whenever the selected zone changes to the selected mode (via app, Flow, or widget).",
          "de": "Wird ausgelöst, sobald der gewählte Bereich auf den gewählten Modus wechselt (über App, Flow oder Widget)."
        },
        "args": [
          {
            "name": "zone",
            "type": "autocomplete",
            "title": {
              "en": "Zone",
              "de": "Bereich"
            },
            "placeholder": {
              "en": "Pick a zone…",
              "de": "Bereich wählen…"
            }
          },
          {
            "name": "mode",
            "type": "dropdown",
            "title": {
              "en": "Mode",
              "de": "Modus"
            },
            "values": [
              {
                "id": "off",
                "label": {
                  "en": "Off",
                  "de": "Aus"
                }
              },
              {
                "id": "day",
                "label": {
                  "en": "Adaptive",
                  "de": "Adaptiv"
                }
              },
              {
                "id": "night",
                "label": {
                  "en": "Night",
                  "de": "Nacht"
                }
              }
            ]
          }
        ]
      }
    ],
    "conditions": [
      {
        "id": "mode_is",
        "title": {
          "en": "Mode is ...",
          "de": "Modus ist ..."
        },
        "titleFormatted": {
          "en": "[[zone]] mode !{{is|is not}} [[mode]]",
          "de": "[[zone]] Modus !{{ist|ist nicht}} [[mode]]"
        },
        "args": [
          {
            "name": "zone",
            "type": "autocomplete",
            "title": {
              "en": "Zone",
              "de": "Bereich"
            },
            "placeholder": {
              "en": "Pick a zone…",
              "de": "Bereich wählen…"
            }
          },
          {
            "name": "mode",
            "type": "dropdown",
            "title": {
              "en": "Mode",
              "de": "Modus"
            },
            "values": [
              {
                "id": "off",
                "label": {
                  "en": "Off",
                  "de": "Aus"
                }
              },
              {
                "id": "day",
                "label": {
                  "en": "Adaptive",
                  "de": "Adaptiv"
                }
              },
              {
                "id": "night",
                "label": {
                  "en": "Night",
                  "de": "Nacht"
                }
              }
            ]
          }
        ]
      }
    ]
  },
  "widgets": {
    "zone-mode": {
      "id": "zone-mode",
      "name": {
        "en": "Lumina zone mode",
        "de": "Lumina-Bereich Modus"
      },
      "height": 96,
      "settings": [
        {
          "id": "zone",
          "type": "autocomplete",
          "title": {
            "en": "Zone",
            "de": "Bereich"
          }
        }
      ],
      "api": {
        "getStatus": {
          "method": "GET",
          "path": "/status"
        },
        "setMode": {
          "method": "POST",
          "path": "/mode"
        }
      }
    }
  },
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png"
  },
  "author": {
    "name": "3cheesehigh",
    "email": "hello@3cheesehigh.com"
  },
  "source": "https://github.com/3cheesehigh/homey-lumina",
